---
/**
 * Rocco — the LittleShredder mascot (SVG from design lines 105–108 / 184).
 * Renders the smiling-helmet face inside a circular avatar, with an optional
 * speech bubble above and an optional name caption below.
 */
interface Props {
  /** Optional speech-bubble text shown above the avatar (omit to hide). */
  bubble?: string;
  /** Optional name caption shown below the avatar (e.g. "I'm Rocco"). */
  caption?: string;
  /** Avatar diameter in px. */
  size?: number;
  /** Background gradient for the avatar disc. */
  variant?: 'sky' | 'warm';
}
const { bubble, caption, size = 134, variant = 'sky' } = Astro.props;
const svgSize = Math.round(size * 0.9);
const bg =
  variant === 'warm'
    ? 'radial-gradient(circle at 50% 36%,#fff,#ffe2d4)'
    : 'radial-gradient(circle at 50% 36%,#e6f3ff,#1a1430)';
---

<div style="position:relative;display:inline-block">
  {bubble && (
    <div
      style="position:absolute;top:-34px;left:-126px;background:#fff;color:#1a1430;font-size:13px;font-weight:800;padding:9px 14px;border-radius:14px 14px 4px 14px;box-shadow:0 8px 20px rgba(0,0,0,.22);transform:rotate(-3deg);white-space:nowrap"
    >
      {bubble}
    </div>
  )}
  <div
    style={`position:relative;width:${size}px;height:${size}px;border-radius:999px;background:${bg};border:4px solid #fff;box-shadow:0 14px 32px rgba(0,0,0,.32);display:flex;align-items:flex-end;justify-content:center;overflow:hidden`}
  >
    <svg width={svgSize} height={Math.round(svgSize * 0.98)} viewBox="0 0 220 200">
      <circle cx="108" cy="92" r="70" fill="#ff5a4d"></circle>
      <path d="M44 112 q12 58 64 58 q56 0 66 -52 q-30 24 -66 24 q-44 0 -64 -30 z" fill="#d6391f"></path>
      <path d="M58 100 q10 40 50 40 q42 0 50 -40 q-26 14 -50 14 q-28 0 -50 -14 z" fill="#fff3ec"></path>
      <rect x="56" y="60" width="104" height="40" rx="20" fill="#1a1430"></rect>
      <rect x="64" y="67" width="34" height="13" rx="6.5" fill="#1fb6a6"></rect>
      <path d="M46 64 q62 -36 126 -4 q-7 -18 -30 -25 q-42 -12 -78 4 q-15 9 -18 25 z" fill="#1a1430"></path>
      <path d="M90 126 q18 13 36 0" stroke="#1a1430" stroke-width="4" fill="none" stroke-linecap="round"></path>
    </svg>
  </div>
  {caption && (
    <span
      style="position:absolute;bottom:-10px;left:50%;transform:translateX(-50%) rotate(-4deg);background:#1a1430;color:#fff;font-size:11px;font-weight:800;padding:4px 12px;border-radius:999px;box-shadow:0 4px 10px rgba(0,0,0,.25);white-space:nowrap"
    >
      {caption}
    </span>
  )}
</div>
