---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import GroupSection from '../../components/GroupSection.astro';
import SourceList from '../../components/SourceList.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Gallery from '../../components/Gallery.astro';

export async function getStaticPaths() {
  const parks = await getCollection('parks');
  return parks.map((entry) => ({
    params: { slug: entry.id },
    props: { park: entry.data, slug: entry.id },
  }));
}

const { park, slug } = Astro.props;

// Editorial layer (optional): your photos + prose, matched by the `park` reference.
const editorial = (await getCollection('parkContent')).find((e) => e.data.park.id === slug);
const Editorial = editorial ? (await render(editorial)).Content : null;

// Related blog posts (relation): posts that reference this park.
const blogPosts = await getCollection('blog', ({ data }) => import.meta.env.DEV || !data.draft);
const related = blogPosts
  .filter((p) => p.data.parks.some((r) => r.id === slug))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const coords = park.coords;
const mapsUrl = coords
  ? `https://www.google.com/maps/search/?api=1&query=${coords.lat},${coords.lng}`
  : null;
---

<BaseLayout
  title={park.overview.name}
  description={`Researched, sourced facts for ${park.overview.name} — ${park.region_label}.`}
>
  <p class="crumb"><a href="/parks/">Parks</a></p>
  <article>
    <header class="page-hero">
      <h1 set:html={park.name} />
      <p class="pk-region">{park.region_label}</p>
      {mapsUrl && (
        <a class="map-link" href={mapsUrl} target="_blank" rel="noopener">View on Google Maps &rarr;</a>
      )}
    </header>

    {editorial?.data.heroImage && (
      <Image
        class="hero-img"
        src={editorial.data.heroImage}
        alt={editorial.data.heroAlt ?? park.overview.name}
      />
    )}
    {Editorial && (
      <section class="editorial">
        <Editorial />
      </section>
    )}
    {editorial && editorial.data.gallery.length > 0 && <Gallery images={editorial.data.gallery} />}

    {park.groups.map((g) => <GroupSection group={g} />)}

    <SourceList parkNo={park.parkNo} sources={park.sources} />

    {related.length > 0 && <RelatedPosts posts={related} heading="Posts about this park" />}

    <a class="back-link" href="/parks/">&larr; All parks</a>
  </article>
</BaseLayout>
